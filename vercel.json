{
    "redirects": [
        {
            "source": "/((?!maintenance\\.html|IMAGES/|favicon_io/|fonts/|api/).*)",
            "destination": "/maintenance.html",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://padel-arena-backend.vercel.app/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}